<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>

<BorderPane fx:id="mainContainer" prefHeight="768.0" prefWidth="1024.0"
            stylesheets="@../css/application.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pmrs.controller.MainLayoutController">

<left>
    <VBox prefWidth="250.0" spacing="15.0" styleClass="sidebar-pane" BorderPane.alignment="CENTER">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
        </padding>

        <Label styleClass="sidebar-header" text="PMRS" textFill="WHITE">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
            <VBox.margin>
                <Insets bottom="30.0" />
            </VBox.margin>
        </Label>

        <Button fx:id="navDashboardBtn" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#onNavigateToDashboard"
                styleClass="nav-button" text="Dashboard" />

        <Button fx:id="navPatientsBtn" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#onNavigateToPatients"
                styleClass="nav-button" text="Patient Directory" />

        <Button fx:id="navAppointmentsBtn" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#onNavigateToAppointments"
                styleClass="nav-button" text="Schedule" />

        <Region VBox.vgrow="ALWAYS" />

        <Button fx:id="navLogoutBtn" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#onLogout"
                styleClass="nav-button-secondary" text="Log Out" />
    </VBox>
</left>

<center>
    <StackPane fx:id="centerContentArea" styleClass="content-pane" BorderPane.alignment="CENTER">
        <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
        </padding>
    </StackPane>
</center>

</BorderPane>