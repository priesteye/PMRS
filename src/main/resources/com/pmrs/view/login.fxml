<?xml version="1.0" encoding="UTF-8"?>

 <?import javafx.geometry.Insets?>
 <?import javafx.scene.layout.VBox?>
 <?import javafx.scene.control.Label?>
 <?import javafx.scene.text.Font?>
 <?import javafx.scene.control.Button?>
 <?import javafx.scene.control.TextField?>
 <?import javafx.scene.control.PasswordField?>
 <?import javafx.scene.control.Label?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.lang.*?>
<?import java.util.*?>


 <VBox alignment="CENTER" spacing="20.0"
       stylesheets="@../css/application.css"
       xmlns="http://javafx.com/javafx/17"
       xmlns:fx="http://javafx.com/fxml"
       fx:controller="com.pmrs.controller.LoginController">

<padding>
    <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
</padding>

<Label styleClass="header-label" text="PMRS Secure Login">
    <font>
        <Font name="System Bold" size="24.0" />
    </font>
</Label>

<VBox maxWidth="300.0" spacing="5.0">
    <Label text="System ID (Physician or Admin)" />
    <TextField fx:id="usernameField" promptText="e.g. DOC-001" />
</VBox>

<VBox maxWidth="300.0" spacing="5.0">
    <Label text="Password" />
    <PasswordField fx:id="passwordField" promptText="Enter your password" />
</VBox>

<Label fx:id="inlineErrorLabel" maxWidth="300.0" textFill="#d32f2f" wrapText="true" />

<Button defaultButton="true" mnemonicParsing="false" onAction="#handleLogin"
        prefWidth="300.0" styleClass="primary-button" text="Sign In" />

</VBox>