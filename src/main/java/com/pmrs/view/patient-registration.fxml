<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" stylesheets="@../css/application.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pmrs.controller.PatientRegistrationController">

    <VBox spacing="25.0" styleClass="content-pane">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox spacing="5.0">
            <Label styleClass="page-header" text="Patient Registration" textFill="#2c3e50">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            <Label text="Enter patient demographic and clinical details." textFill="#7f8c8d" />

            <Label fx:id="globalMessageLabel" wrapText="true">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Label>
        </VBox>

        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="120.0" prefWidth="150.0" />
                <ColumnConstraints minWidth="250.0" prefWidth="300.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" /> </columnConstraints>

            <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="firstNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label fx:id="firstNameError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="0" />

            <Label text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="lastNameField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="lastNameError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="1" />

            <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <DatePicker fx:id="dobPicker" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="dobError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="2" />

            <Label text="Gender:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <ComboBox fx:id="genderComboBox" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label fx:id="genderError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="3" />

            <Label text="Contact Number:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="contactNumberField" promptText="e.g. 555-0199" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label fx:id="contactNumberError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="4" />

            <Label text="Street Address:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <TextField fx:id="streetField" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label fx:id="streetError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="5" />

            <Label text="City:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <TextField fx:id="cityField" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <Label fx:id="cityError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="6" />

            <Label text="State / Zip:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="7">
                <TextField fx:id="stateField" prefWidth="145.0" promptText="State" />
                <TextField fx:id="zipField" prefWidth="145.0" promptText="Zip Code" />
            </HBox>
            <Label fx:id="stateZipError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="7" />

            <Label text="Blood Type:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
            <ComboBox fx:id="bloodTypeComboBox" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="8" />
            <Label fx:id="bloodTypeError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="8" />

            <Label text="Emergency Contact:" GridPane.columnIndex="0" GridPane.rowIndex="9" />
            <TextField fx:id="emergencyContactField" promptText="Name &amp; Number" GridPane.columnIndex="1" GridPane.rowIndex="9" />
            <Label fx:id="emergencyContactError" textFill="#d32f2f" GridPane.columnIndex="2" GridPane.rowIndex="9" />

            <Label text="Allergies:" GridPane.columnIndex="0" GridPane.rowIndex="10" />
            <TextField fx:id="allergiesField" promptText="Comma separated (optional)" GridPane.columnIndex="1" GridPane.rowIndex="10" />
        </GridPane>

        <HBox spacing="15.0">
            <padding>
                <Insets top="20.0" />
            </padding>
            <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSubmit"
                    prefHeight="40.0" prefWidth="150.0" styleClass="primary-button" text="Register Patient" />
            <Button mnemonicParsing="false" onAction="#clearForm"
                    prefHeight="40.0" prefWidth="100.0" styleClass="secondary-button" text="Clear Form" />
        </HBox>
    </VBox>
</ScrollPane>
