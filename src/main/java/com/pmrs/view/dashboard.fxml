<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="30.0"
      stylesheets="@../css/application.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pmrs.controller.DashboardController">

<padding>
    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
</padding>

<VBox spacing="5.0">
    <Label fx:id="welcomeLabel" styleClass="page-header" text="Clinic Dashboard" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>
    <Label text="Overview and quick actions for today." textFill="#7f8c8d">
        <font>
            <Font size="14.0" />
        </font>
    </Label>
</VBox>

<HBox spacing="20.0">
    <VBox alignment="CENTER" prefHeight="120.0" prefWidth="220.0" styleClass="stat-card">
        <Label styleClass="stat-title" text="Total Patients" textFill="#34495e">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <Label fx:id="totalPatientsLabel" styleClass="stat-value" text="0" textFill="#2980b9">
            <font>
                <Font name="System Bold" size="48.0" />
            </font>
        </Label>
    </VBox>

    <VBox alignment="CENTER" prefHeight="120.0" prefWidth="220.0" styleClass="stat-card">
        <Label styleClass="stat-title" text="Today's Appointments" textFill="#34495e">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <Label fx:id="todayAppointmentsLabel" styleClass="stat-value" text="0" textFill="#27ae60">
            <font>
                <Font name="System Bold" size="48.0" />
            </font>
        </Label>
    </VBox>
</HBox>

<VBox spacing="15.0">
    <Label styleClass="section-header" text="Quick Actions" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>
    <HBox spacing="15.0">
        <Button mnemonicParsing="false" onAction="#onRegisterPatient"
                prefHeight="40.0" prefWidth="180.0" styleClass="primary-button"
                text="Register New Patient" />

        <Button mnemonicParsing="false" onAction="#onScheduleAppointment"
                prefHeight="40.0" prefWidth="180.0" styleClass="secondary-button"
                text="Schedule Appointment" />
    </HBox>
</VBox>

</VBox>